{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "routes": [
          {
                  "handle": "filesystem"
          },
          {
                  "src": "/api/(.*)",
                  "dest": "https://smartsec-backend.onrender.com/$1"
          },
          {
                  "src": "/(.*)",
                  "dest": "/index.html"
          }
    ],
    "headers": [
          {
                  "source": "/(.*)",
                  "headers": [
                            { "key": "X-Content-Type-Options", "value": "nosniff" },
                            { "key": "X-Frame-Options", "value": "DENY" },
                            { "key": "X-XSS-Protection", "value": "1; mode=block" },
                            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                            {
                                        "key": "Content-Security-Policy",
                                        "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://smartsec-backend.onrender.com https://*.supabase.co wss://*.supabase.co;"
                            }
                  ]
          }
    ]
}
